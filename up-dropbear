#!/bin/bash

# ──────────────────────────────────────────────────────────────
#  Color & Style Definitions
# ──────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
ORANGE='\033[0;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
WHITE='\033[1;37m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m' # No Color / Reset

# ──────────────────────────────────────────────────────────────
#  Helper: install dropbear dari versi tertentu
# ──────────────────────────────────────────────────────────────
install_dropbear() {
    local version="$1"
    local tarball="dropbear-${version}.tar.bz2"
    local url="https://matt.ucc.asn.au/dropbear/releases/${tarball}"
    local srcdir="dropbear-${version}"

    echo -e "\n${CYAN}  [*] Mengunduh Dropbear ${version}...${NC}"
    wget -q --show-progress "$url" || {
        echo -e "${RED}  [✗] Gagal mengunduh! Periksa koneksi internet.${NC}"
        return 1
    }

    echo -e "${CYAN}  [*] Mengekstrak arsip...${NC}"
    bzip2 -cd "$tarball" | tar xvf - > /dev/null 2>&1

    echo -e "${CYAN}  [*] Mengkompilasi...${NC}"
    cd "$srcdir" || return 1
    ./configure > /dev/null 2>&1
    make > /dev/null 2>&1 && make install > /dev/null 2>&1

    echo -e "${CYAN}  [*] Mengganti binary lama...${NC}"
    [[ -f /usr/sbin/dropbear ]] && mv /usr/sbin/dropbear /usr/sbin/dropbear1
    ln -sf /usr/local/sbin/dropbear /usr/sbin/dropbear

    echo -e "${CYAN}  [*] Menambahkan shell entries...${NC}"
    grep -qxF '/bin/false'        /etc/shells || echo "/bin/false"        >> /etc/shells
    grep -qxF '/usr/sbin/nologin' /etc/shells || echo "/usr/sbin/nologin" >> /etc/shells

    echo -e "${CYAN}  [*] Me-restart Dropbear...${NC}"
    /etc/init.d/dropbear restart > /dev/null 2>&1 || service dropbear restart > /dev/null 2>&1

    cd /root > /dev/null 2>&1 || cd ~
    rm -rf "$tarball" "$srcdir"

    echo -e "\n${GREEN}  [✓] Dropbear ${version} berhasil diinstall!${NC}"
}

# ──────────────────────────────────────────────────────────────
#  Main Function
# ──────────────────────────────────────────────────────────────
dropbear_update() {
    clear
    echo -e "${ORANGE}╔══════════════════════════════════════════╗${NC}"
    echo -e "${ORANGE}║${NC}  ${BOLD}${WHITE}      ⚙  UPDATE VERSI DROPBEAR  ⚙       ${NC}${ORANGE}║${NC}"
    echo -e "${ORANGE}╠══════════════════════════════════════════╣${NC}"
    echo -e "${ORANGE}║${NC}                                          ${ORANGE}║${NC}"
    echo -e "${ORANGE}║${NC}   ${GREEN}[1]${NC} ${WHITE}Dropbear${NC} ${DIM}2017.75${NC}                   ${ORANGE}║${NC}"
    echo -e "${ORANGE}║${NC}   ${GREEN}[2]${NC} ${WHITE}Dropbear${NC} ${DIM}2019.78${NC}                   ${ORANGE}║${NC}"
    echo -e "${ORANGE}║${NC}   ${GREEN}[3]${NC} ${WHITE}Dropbear${NC} ${DIM}2022.82${NC}                   ${ORANGE}║${NC}"
    echo -e "${ORANGE}║${NC}   ${GREEN}[4]${NC} ${WHITE}Dropbear${NC} ${DIM}2024.84${NC}                   ${ORANGE}║${NC}"
    echo -e "${ORANGE}║${NC}   ${GREEN}[5]${NC} ${WHITE}Dropbear${NC} ${DIM}2025.87${NC}  ${YELLOW}★ Latest${NC}         ${ORANGE}║${NC}"
    echo -e "${ORANGE}║${NC}                                          ${ORANGE}║${NC}"
    echo -e "${ORANGE}║${NC}   ${RED}[x]${NC} ${DIM}Keluar / Kembali${NC}                   ${ORANGE}║${NC}"
    echo -e "${ORANGE}║${NC}                                          ${ORANGE}║${NC}"
    echo -e "${ORANGE}╚══════════════════════════════════════════╝${NC}"

    echo -ne "\n  ${CYAN}Pilih opsi ${WHITE}[1-5 / x]${CYAN} → ${NC}"
    read -r pilihan

    case $pilihan in
        1) install_dropbear "2017.75" ;;
        2) install_dropbear "2019.78" ;;
        3) install_dropbear "2022.82" ;;
        4) install_dropbear "2024.84" ;;
        5) install_dropbear "2025.87" ;;
        x|X) 
            echo -e "  ${DIM}Keluar...${NC}"
            exit 0 
            ;;
        *)
            echo -e "  ${RED}[✗] Pilihan tidak valid.${NC}"
            sleep 2
            dropbear_update
            ;;
    esac

    echo -e "\n${ORANGE}──────────────────────────────────────────${NC}"
    echo -ne "  ${DIM}Tekan ${WHITE}[Enter]${DIM} untuk kembali ke menu...${NC}"
    read -r
    dropbear_update
}

# Menjalankan fungsi utama
dropbear_update
